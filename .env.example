# PostgreSQL connection string for the Knockout City server database.
# The database is provided by your Knockout City server — point this at it directly.
#
# If using the ServerDocker compose setup (recommended), use:
DATABASE_URL=postgres://postgres:postgres@postgres:5432/koc
#
# If connecting to an external / custom database:
# DATABASE_URL=postgres://user:password@host:5432/koc
